# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
MOCK_MODE=false
MOCK_MARKET_DATA=false

# Database
DATABASE_URL=postgresql://sentiment_user:sentiment_pass@localhost:5432/sentiment_watchlist

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRY=24h
BCRYPT_ROUNDS=12

# External APIs
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
COINGECKO_API_KEY=
COINGECKO_API_KEY_HEADER=x-cg-demo-api-key
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
NEWSAPI_KEY=your_newsapi_key
NEWSAPI_BASE_URL=https://newsapi.org/v2
GNEWS_KEY=your_gnews_key
GNEWS_BASE_URL=https://gnews.io/api/v4
FRANKFURTER_BASE_URL=https://api.frankfurter.app

# Sentiment engine
SENTIMENT_ENGINE_URL=http://localhost:8000

# Daily quotas
ALPHA_VANTAGE_DAILY_LIMIT=25
NEWSAPI_DAILY_LIMIT=100
GNEWS_DAILY_LIMIT=100

# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_ENABLE_DEMO_FALLBACK=false
